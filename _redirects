# Netlify Redirects
# Format: /old-path/   /new-path/   301
# 301 = permanent (use for renamed slugs after the site is live)
# 302 = temporary (use when a page is moving but may move again)
#
# ── COMING SOON — remove these two lines when ready to launch ──────────────
/admin/*  /admin/:splat  200
/*        /coming-soon/  302
