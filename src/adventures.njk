---
layout: base.njk
title: Adventures
permalink: /adventures/
---
{% block head %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
{% endblock %}

<section class="page-hero">
  <div class="container">
    <h1>Adventures</h1>
    <p>Pilgrimages, travels, and journeys around the world.</p>
  </div>
</section>

<!-- ===================== MAP ===================== -->
<section class="adventures-map-section">
  <div id="adventures-map" style="height:500px" aria-label="Map of adventures"></div>
</section>

<!-- ===================== GRID ===================== -->
<section class="section">
  <div class="container">

    <!-- Filter buttons -->
    <div class="filter-bar" role="group" aria-label="Filter adventures by category">
      <button class="filter-btn filter-btn--active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="pilgrimage">Pilgrimage</button>
      <button class="filter-btn" data-filter="travel">Travel</button>
      <button class="filter-btn" data-filter="retreat">Retreat</button>
      <button class="filter-btn" data-filter="parish">Parish</button>
      <button class="filter-btn" data-filter="personal">Personal</button>
    </div>

    <div class="overlay-grid" id="adventures-grid">
      {% for adv in collections.adventure %}
      <a href="{{ adv.url }}" class="overlay-card" data-category="{{ adv.data.category }}">
        {% if adv.data.coverImage %}
        <img class="overlay-card__img" src="{{ adv.data.coverImage }}" alt="{{ adv.data.title }}" loading="lazy"{% if adv.data.coverImagePosition %} style="object-position: {{ adv.data.coverImagePosition }}"{% endif %} />
        {% else %}
        <div class="overlay-card__img overlay-card__img--placeholder"></div>
        {% endif %}
        <div class="overlay-card__overlay"></div>
        <div class="overlay-card__info">
          <span class="overlay-card__meta">
            {% if adv.data.category %}{{ adv.data.category }}{% endif %}
            {% if adv.data.category and adv.data.location %} &middot; {% endif %}
            {% if adv.data.location %}{{ adv.data.location }}{% if adv.data.country %}, {{ adv.data.country }}{% endif %}{% endif %}
          </span>
          <span class="overlay-card__title">{{ adv.data.title }}</span>
        </div>
      </a>
      {% else %}
      <p>No adventures yet.</p>
      {% endfor %}
    </div>
  </div>
</section>

{% block scripts %}
<script>
  // ---- Map init ----
  const map = L.map('adventures-map', { scrollWheelZoom: false }).setView([20, 10], 2);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
    maxZoom: 18
  }).addTo(map);

  const pinIcon = L.divIcon({
    className: 'map-pin',
    html: '<span></span>',
    iconSize: [16, 16],
    iconAnchor: [8, 8],
    popupAnchor: [0, -12]
  });

  // Adventure data serialised from Eleventy collections
  const adventures = [
    {% for adv in collections.adventure %}
    {% if adv.data.lat and adv.data.lng %}
    {
      title: {{ adv.data.title | json | safe }},
      url: {{ adv.url | json | safe }},
      location: {{ (adv.data.location or '') | json | safe }},
      date: {{ adv.date | dateFormat('MMMM d, yyyy') | json | safe }},
      lat: {{ adv.data.lat }},
      lng: {{ adv.data.lng }}
    }{% if not loop.last %},{% endif %}
    {% endif %}
    {% endfor %}
  ];

  adventures.forEach(adv => {
    L.marker([adv.lat, adv.lng], { icon: pinIcon })
      .addTo(map)
      .bindPopup(`
        <strong>${adv.title}</strong><br/>
        ${adv.date}<br/>
        ${adv.location}<br/>
        <a href="${adv.url}">Read more &rarr;</a>
      `);
  });

  // ---- Category filter ----
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('#adventures-grid .overlay-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');
      const filter = btn.dataset.filter;
      cards.forEach(card => {
        card.style.display = (filter === 'all' || card.dataset.category === filter) ? '' : 'none';
      });
    });
  });
</script>
{% endblock %}
