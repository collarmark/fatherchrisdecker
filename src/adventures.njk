---
layout: base.njk
title: Adventures
permalink: /adventures/
---
{% block head %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
{% endblock %}

<section class="page-hero">
  <div class="container">
    <h1>Adventures</h1>
    <p>Pilgrimages, travels, and journeys around the world.</p>
  </div>
</section>

<!-- ===================== MAP ===================== -->
<section class="adventures-map-section">
  <div id="adventures-map" aria-label="Map of adventures"></div>
</section>

<!-- ===================== GRID ===================== -->
<section class="section">
  <div class="container">

    <!-- Filter buttons -->
    <div class="filter-bar" role="group" aria-label="Filter adventures by category">
      <button class="filter-btn filter-btn--active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="pilgrimage">Pilgrimage</button>
      <button class="filter-btn" data-filter="travel">Travel</button>
      <button class="filter-btn" data-filter="retreat">Retreat</button>
      <button class="filter-btn" data-filter="parish">Parish</button>
      <button class="filter-btn" data-filter="personal">Personal</button>
    </div>

    <div class="card-grid" id="adventures-grid">
      {% for adv in collections.adventure %}
      <article class="card" data-category="{{ adv.data.category }}">
        {% if adv.data.coverImage %}
        <a href="{{ adv.url }}" class="card__img-link">
          <img src="{{ adv.data.coverImage }}" alt="{{ adv.data.title }}" loading="lazy" />
        </a>
        {% endif %}
        <div class="card__body">
          <p class="card__meta">
            {% if adv.data.category %}<span class="tag tag--{{ adv.data.category }}">{{ adv.data.category }}</span>{% endif %}
            <time datetime="{{ adv.date | dateFormat('yyyy-MM-dd') }}">{{ adv.date | dateFormat('MMM yyyy') }}</time>
          </p>
          <h2 class="card__title"><a href="{{ adv.url }}">{{ adv.data.title }}</a></h2>
          {% if adv.data.location %}<p class="card__location">{{ adv.data.location }}{% if adv.data.country %}, {{ adv.data.country }}{% endif %}</p>{% endif %}
        </div>
      </article>
      {% else %}
      <p>No adventures yet.</p>
      {% endfor %}
    </div>
  </div>
</section>

{% block scripts %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV/XN/WLcE=" crossorigin=""></script>
<script>
  // ---- Map init ----
  const map = L.map('adventures-map', { scrollWheelZoom: false }).setView([20, 10], 2);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
    maxZoom: 18
  }).addTo(map);

  const pinIcon = L.divIcon({
    className: 'map-pin',
    html: '<span></span>',
    iconSize: [16, 16],
    iconAnchor: [8, 8],
    popupAnchor: [0, -12]
  });

  // Adventure data serialised from Eleventy collections
  const adventures = [
    {% for adv in collections.adventure %}
    {% if adv.data.lat and adv.data.lng %}
    {
      title: {{ adv.data.title | json | safe }},
      url: {{ adv.url | json | safe }},
      location: {{ (adv.data.location or '') | json | safe }},
      date: {{ adv.date | dateFormat('MMMM d, yyyy') | json | safe }},
      lat: {{ adv.data.lat }},
      lng: {{ adv.data.lng }}
    }{% if not loop.last %},{% endif %}
    {% endif %}
    {% endfor %}
  ];

  adventures.forEach(adv => {
    L.marker([adv.lat, adv.lng], { icon: pinIcon })
      .addTo(map)
      .bindPopup(`
        <strong>${adv.title}</strong><br/>
        ${adv.date}<br/>
        ${adv.location}<br/>
        <a href="${adv.url}">Read more &rarr;</a>
      `);
  });

  // ---- Category filter ----
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('#adventures-grid .card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');
      const filter = btn.dataset.filter;
      cards.forEach(card => {
        card.style.display = (filter === 'all' || card.dataset.category === filter) ? '' : 'none';
      });
    });
  });
</script>
{% endblock %}
