---
pagination:
  data: collections.pageAliases
  size: 1
  alias: r
permalink: "/{{ r.alias }}/"
---
<!doctype html>
<html>
<head>
  <meta http-equiv="refresh" content="0; url={{ r.target }}">
  <link rel="canonical" href="{{ r.target }}">
</head>
<body>
  <p>Redirecting… <a href="{{ r.target }}">click here if not redirected</a>.</p>
</body>
</html>
