---
layout: base.njk
---
{% block content %}

{% set prevAdventure = collections.adventure | collectionNext(page.url) %}
{% set nextAdventure = collections.adventure | collectionPrev(page.url) %}

{% if coverImage and not hideHeroImage %}
<div class="post-banner">
  <img class="post-banner__img" src="{{ coverImage }}" alt="{{ title }}" loading="eager"{% if coverImagePosition %} style="object-position: {{ coverImagePosition }}"{% endif %} />
  <div class="post-banner__overlay"></div>
  <div class="post-banner__text">
    <h1 class="post-banner__title">{{ title }}</h1>
    <p class="post-banner__meta">
      {% if category %}<span class="tag tag--{{ category }}">{{ category }}</span> {% endif %}
      {% if location %}{{ location }}{% if country %}, {{ country }}{% endif %}{% endif %}
    </p>
  </div>
</div>
{% endif %}

<article class="adventure container prose">

  <header class="adventure__header">
    <p class="adventure__meta">
      {% if category %}<span class="tag tag--{{ category }}">{{ category }}</span>{% endif %}
      <time datetime="{{ date | dateFormat('yyyy-MM-dd') }}{% if time %}T{{ time }}{% endif %}">{{ date | dateFormat('MMMM d, yyyy') }}{% if time %} &middot; {{ time }}{% endif %}</time>
      {% if location %}&middot; {{ location }}{% if country %}, {{ country }}{% endif %}{% endif %}
    </p>
    {% if not coverImage or hideHeroImage %}
    <h1 class="adventure__title">{{ title }}</h1>
    {% endif %}
  </header>

  <div class="adventure__body">
    {{ content | safe }}
  </div>

  <nav class="post-nav" aria-label="Adventure navigation">
    <div class="post-nav__prev">
      {% if prevAdventure %}
      <span class="post-nav__label">&larr; Previous</span>
      <a href="{{ prevAdventure.url }}" class="post-nav__title">{{ prevAdventure.data.title }}</a>
      {% endif %}
    </div>
    <div class="post-nav__back">
      <a href="/adventures/" class="btn btn--outline btn--sm">Back to Adventures</a>
    </div>
    <div class="post-nav__next">
      {% if nextAdventure %}
      <span class="post-nav__label">Next &rarr;</span>
      <a href="{{ nextAdventure.url }}" class="post-nav__title">{{ nextAdventure.data.title }}</a>
      {% endif %}
    </div>
  </nav>

</article>
{% endblock %}
