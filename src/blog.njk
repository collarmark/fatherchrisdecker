---
layout: base.njk
title: Blog
permalink: /blog/
---

<section class="page-hero">
  <div class="container">
    <h1>Blog</h1>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="overlay-grid">
      {% for post in collections.post %}
      <a href="{{ post.url }}" class="overlay-card">
        {% if post.data.image %}
        <img class="overlay-card__img" src="{{ post.data.image }}" alt="{{ post.data.title }}" loading="lazy"{% if post.data.coverImagePosition %} style="object-position: {{ post.data.coverImagePosition }}"{% endif %} />
        {% else %}
        <div class="overlay-card__img overlay-card__img--placeholder"></div>
        {% endif %}
        <div class="overlay-card__overlay"></div>
        <div class="overlay-card__info">
          <span class="overlay-card__meta">{{ post.date | dateFormat('MMMM d, yyyy') }}</span>
          <span class="overlay-card__title">{{ post.data.title }}</span>
          {% if post.data.excerpt %}<span class="overlay-card__excerpt">{{ post.data.excerpt }}</span>{% endif %}
        </div>
      </a>
      {% else %}
      <p>No posts yet. Check back soon.</p>
      {% endfor %}
    </div>
  </div>
</section>
