  </div>
</section>

{# ===================== RECENT POSTS ===================== #}
<section class="section home-row">
  <div class="container">
    <div class="home-row__header">
      <p class="home-row__eyebrow">Writing</p>
      <div class="home-row__title-row">
        <h2 class="home-row__title">Recent Posts</h2>
        <a href="/blog/" class="home-row__viewall">View all &rarr;</a>
      </div>
      <div class="home-row__rule"></div>
    </div>
    <div class="home-row__grid">
      {% for post in collections.post | limit(3) %}
      <a href="{{ post.url }}" class="overlay-card">
        {% if post.data.image %}
        <img class="overlay-card__img" src="{{ post.data.image }}" alt="{{ post.data.title }}" loading="lazy"{% if post.data.coverImagePosition %} style="object-position: {{ post.data.coverImagePosition }}"{% endif %} />
        {% else %}
        <div class="overlay-card__img overlay-card__img--placeholder"></div>
        {% endif %}
        <div class="overlay-card__overlay"></div>
        <div class="overlay-card__info">
          <span class="overlay-card__meta">{{ post.date | dateFormat('MMMM d, yyyy') }}</span>
          <span class="overlay-card__title">{{ post.data.title }}</span>
        </div>
      </a>
      {% else %}
      <p class="section__empty">No posts yet — check back soon.</p>
      {% endfor %}
    </div>
  </div>
</section>

{# ===================== ADVENTURES ===================== #}
<section class="section section--light home-row">
  <div class="container">
    <div class="home-row__header">
      <p class="home-row__eyebrow">Travel</p>
      <div class="home-row__title-row">
        <h2 class="home-row__title">Adventures</h2>
        <a href="/adventures/" class="home-row__viewall">View all &rarr;</a>
      </div>
      <div class="home-row__rule"></div>
    </div>
    <div class="home-row__grid">
      {% for adv in collections.adventure | limit(3) %}
      <a href="{{ adv.url }}" class="overlay-card">
        {% if adv.data.coverImage %}
        <img class="overlay-card__img" src="{{ adv.data.coverImage }}" alt="{{ adv.data.title }}" loading="lazy"{% if adv.data.coverImagePosition %} style="object-position: {{ adv.data.coverImagePosition }}"{% endif %} />
        {% else %}
        <div class="overlay-card__img overlay-card__img--placeholder"></div>
        {% endif %}
        <div class="overlay-card__overlay"></div>
        <div class="overlay-card__info">
          <span class="overlay-card__meta">{{ adv.data.location }}{% if adv.data.country %}, {{ adv.data.country }}{% endif %}</span>
          <span class="overlay-card__title">{{ adv.data.title }}</span>
        </div>
      </a>
      {% else %}
      <p class="section__empty">No adventures yet.</p>
      {% endfor %}
    </div>
  </div>
</section>

{# ===================== FROM THE GALLERY ===================== #}
