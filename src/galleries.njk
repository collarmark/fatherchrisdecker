---
layout: base.njk
title: Art & Galleries
permalink: /galleries/
---

<section class="page-hero">
  <div class="container">
    <h1>Art &amp; Galleries</h1>
    <p>Sacred art, sci-fi illustrations, graphic design, and more.</p>
  </div>
</section>

<section class="section">
  <div class="container">

    <!-- Category filter -->
    <div class="filter-bar" role="group" aria-label="Filter galleries by category">
      <button class="filter-btn filter-btn--active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="sacred-art">Sacred Art</button>
      <button class="filter-btn" data-filter="sci-fi">Sci-Fi</button>
      <button class="filter-btn" data-filter="graphic-design">Graphic Design</button>
      <button class="filter-btn" data-filter="inktober">Inktober</button>
      <button class="filter-btn" data-filter="illustration">Illustration</button>
      <button class="filter-btn" data-filter="other">Other</button>
    </div>

    <div class="overlay-grid" id="galleries-grid">
      {% for gallery in collections.gallery %}
      <a href="{{ gallery.url }}" class="overlay-card" data-category="{{ gallery.data.category }}">
        {% if gallery.data.coverImage %}
        <img class="overlay-card__img" src="{{ gallery.data.coverImage }}" alt="{{ gallery.data.title }}" loading="lazy"{% if gallery.data.coverImagePosition %} style="object-position: {{ gallery.data.coverImagePosition }}"{% endif %} />
        {% else %}
        <div class="overlay-card__img overlay-card__img--placeholder"></div>
        {% endif %}
        <div class="overlay-card__overlay"></div>
        <div class="overlay-card__info">
          <span class="overlay-card__meta">
            {% if gallery.data.category %}{{ gallery.data.category | replace("-", " ") }}{% endif %}
            {% if gallery.data.year %} &middot; {{ gallery.data.year }}{% endif %}
          </span>
          <span class="overlay-card__title">{{ gallery.data.title }}</span>
        </div>
      </a>
      {% else %}
      <p>No galleries yet.</p>
      {% endfor %}
    </div>

  </div>
</section>

{% block scripts %}
<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('#galleries-grid .overlay-card');
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');
      const filter = btn.dataset.filter;
      cards.forEach(card => {
        card.style.display = (filter === 'all' || card.dataset.category === filter) ? '' : 'none';
      });
    });
  });
</script>
{% endblock %}
